{% layout 'theme' %}

{{ 'section-placeholder.css' | asset_url | stylesheet_tag }}

<section class="nm-placeholder">
  <div class="nm-container nm-container--narrow nm-placeholder__inner">
    <p class="nm-eyebrow">Gift card</p>
    <h1 class="nm-placeholder__title">{{ shop.name }} — Gift card</h1>
    <p class="nm-placeholder__body">
      Code: <strong>{{ gift_card.code | format_code }}</strong><br>
      Balance: {{ gift_card.balance | money }}
    </p>
  </div>
</section>
