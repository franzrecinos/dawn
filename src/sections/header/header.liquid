{{ 'section-header.css' | asset_url | stylesheet_tag }}

<header class="nm-header" data-section-id="{{ section.id }}">
  <div class="nm-container nm-header__inner">
    <a href="{{ routes.root_url }}" class="nm-header__brand" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: 240
          | image_tag: loading: 'eager', widths: '120, 240, 360', class: 'nm-header__logo'
        }}
      {%- else -%}
        <span class="nm-header__wordmark">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- if section.blocks.size > 0 -%}
      <nav class="nm-header__nav" aria-label="{{ 'sections.header.menu' | t }}">
        <ul class="nm-header__nav-list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'link' -%}
              <li {{ block.shopify_attributes }}>
                <a class="nm-header__nav-link" href="{{ block.settings.link | default: '#' }}">
                  {{ block.settings.label | default: 'Link' }}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <div class="nm-header__actions">
      {%- if section.settings.show_cta -%}
        <a class="nm-button nm-button--accent nm-header__cta" href="{{ section.settings.cta_link | default: '#plans' }}">
          {{ section.settings.cta_label | default: 'Browse plans' }}
        </a>
      {%- endif -%}
      <a class="nm-header__cart" href="{{ routes.cart_url }}" aria-label="{{ 'sections.header.cart' | t }}">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M3 5h2.4l2 11.2a2 2 0 0 0 2 1.6h7.5a2 2 0 0 0 2-1.5L20.5 9H6"/>
          <circle cx="9.5" cy="20" r="1.2"/>
          <circle cx="17" cy="20" r="1.2"/>
        </svg>
        <span class="nm-header__cart-count" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "checkbox", "id": "show_cta", "label": "Show primary CTA", "default": true },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Browse plans" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Nav link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "How it works" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "link", "settings": { "label": "How it works" } },
        { "type": "link", "settings": { "label": "Coverage" } },
        { "type": "link", "settings": { "label": "Plans" } },
        { "type": "link", "settings": { "label": "Help" } }
      ]
    }
  ]
}
{% endschema %}
