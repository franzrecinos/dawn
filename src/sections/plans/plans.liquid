{{ 'section-plans.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-plans.js' | asset_url }}" defer></script>

<section class="nm-plans" id="plans" data-section-id="{{ section.id }}">
  <div class="nm-container">
    <header class="nm-plans__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nm-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="nm-plans__title">{{ section.settings.title | default: 'Pick your destination.' }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="nm-plans__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </header>

    <nm-plan-grid class="nm-plans__grid" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'plan' -%}
          {%- assign price = block.settings.price | default: '$0' -%}
          {%- assign compare = block.settings.compare_at -%}
          <article {{ block.shopify_attributes }} class="nm-plan" role="listitem">
            <div class="nm-plan__head">
              <span class="nm-plan__region">{{ block.settings.region | default: 'Region' }}</span>
              {%- if block.settings.tag != blank -%}
                <span class="nm-plan__tag">{{ block.settings.tag }}</span>
              {%- endif -%}
            </div>

            <div class="nm-plan__stat">
              <span class="nm-plan__stat-value">{{ block.settings.data | default: '5 GB' }}</span>
              <span class="nm-plan__stat-label">data</span>
            </div>
            <div class="nm-plan__stat">
              <span class="nm-plan__stat-value">{{ block.settings.days | default: '15 days' }}</span>
              <span class="nm-plan__stat-label">validity</span>
            </div>

            <div class="nm-plan__price-row">
              {%- if compare != blank -%}
                <span class="nm-plan__compare">{{ compare }}</span>
              {%- endif -%}
              <span class="nm-plan__price">{{ price }}</span>
            </div>

            <a class="nm-button nm-button--primary nm-plan__cta" href="{{ block.settings.link | default: '#' }}">
              {{ block.settings.cta_label | default: 'Choose plan' }}
            </a>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </nm-plan-grid>

    {%- if section.settings.bundle_note != blank -%}
      <p class="nm-plans__bundle-note">{{ section.settings.bundle_note }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Plans",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Plans" },
    { "type": "text", "id": "title", "label": "Title", "default": "Pick your destination." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Stack two or more plans and we'll bundle the discount automatically." },
    { "type": "text", "id": "bundle_note", "label": "Bundle note", "default": "Save 10% on 2 plans. 20% on 3+. Auto-applied at checkout." }
  ],
  "blocks": [
    {
      "type": "plan",
      "name": "Plan card",
      "settings": [
        { "type": "text", "id": "region", "label": "Region or country", "default": "Europe" },
        { "type": "text", "id": "tag", "label": "Tag", "default": "Most popular" },
        { "type": "text", "id": "data", "label": "Data", "default": "5 GB" },
        { "type": "text", "id": "days", "label": "Validity", "default": "15 days" },
        { "type": "text", "id": "compare_at", "label": "Compare-at price" },
        { "type": "text", "id": "price", "label": "Price", "default": "$14" },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Choose plan" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Plans",
      "blocks": [
        { "type": "plan", "settings": { "region": "Europe", "tag": "Most popular", "data": "5 GB", "days": "15 days", "price": "$14", "compare_at": "$18" } },
        { "type": "plan", "settings": { "region": "USA", "data": "10 GB", "days": "30 days", "price": "$22" } },
        { "type": "plan", "settings": { "region": "Asia", "data": "8 GB", "days": "20 days", "price": "$19" } },
        { "type": "plan", "settings": { "region": "Global", "tag": "World coverage", "data": "3 GB", "days": "30 days", "price": "$29" } }
      ]
    }
  ]
}
{% endschema %}
