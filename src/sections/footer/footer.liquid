{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer class="nm-footer" data-section-id="{{ section.id }}">
  <div class="nm-container nm-footer__inner">
    <div class="nm-footer__brand">
      <span class="nm-footer__wordmark">{{ shop.name }}</span>
      {%- if section.settings.tagline != blank -%}
        <p class="nm-footer__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>

    <nav class="nm-footer__nav" aria-label="Footer">
      {%- for block in section.blocks -%}
        {%- if block.type == 'column' -%}
          <div {{ block.shopify_attributes }} class="nm-footer__col">
            <h4 class="nm-footer__col-title">{{ block.settings.title | default: 'Column' }}</h4>
            <ul class="nm-footer__col-list" role="list">
              {%- assign links = block.settings.links | newline_to_br | split: '<br />' -%}
              {%- for entry in links -%}
                {%- assign trimmed = entry | strip -%}
                {%- if trimmed != blank -%}
                  <li><a href="#" class="nm-footer__col-link">{{ trimmed }}</a></li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </nav>
  </div>

  <div class="nm-footer__base nm-container">
    <p class="nm-footer__legal">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    {%- if section.settings.legal_text != blank -%}
      <p class="nm-footer__legal">{{ section.settings.legal_text }}</p>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Travel eSIMs for nomads, families, and bons vivants." },
    { "type": "text", "id": "legal_text", "label": "Legal text" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Product" },
        { "type": "textarea", "id": "links", "label": "Links (one per line)", "default": "Plans\nCoverage\nBundles" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "column", "settings": { "title": "Product", "links": "Plans\nCoverage\nBundles\nFAQ" } },
        { "type": "column", "settings": { "title": "Company", "links": "About\nPress\nContact" } },
        { "type": "column", "settings": { "title": "Legal", "links": "Terms\nPrivacy\nRefunds" } }
      ]
    }
  ]
}
{% endschema %}
